# --- AI answer providers (ordered fallback: Gemini → GitHub Models) ---
# Primary. Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Fallback. A GitHub PAT with the "models" permission.
GITHUB_MODELS_TOKEN=

# --- Grounding: the data plane (shouldknowaboutme) ---
# The X-Api-Key that unlocks gated sections. Same value as shouldknowaboutme's SECRET.
# Optional — without it, answers ground on the public (redacted) content.
SHOULDKNOWABOUTME_API_KEY=

# --- Optional knobs (defaults are sensible; override only if endpoints/models drift) ---
# GEMINI_MODEL=gemini-2.0-flash
# GITHUB_MODELS_MODEL=openai/gpt-4o-mini
# GITHUB_MODELS_URL=https://models.github.ai/inference/chat/completions
# DATA_PLANE_URL=https://shouldknowaboutme.vercel.app
# CONTACT_URL=https://shouldknowaboutyou.vercel.app
